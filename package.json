{
  "name": "sidequest",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "check:package-manager": "node scripts/ensure-pnpm.js",
    "preinstall": "node scripts/ensure-pnpm.js",
    "predev": "node scripts/ensure-pnpm.js && node scripts/sync-local-supabase-env.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/ensure-pnpm.js",
    "build": "next build",
    "prestart": "node scripts/ensure-pnpm.js",
    "start": "next start",
    "prelint": "node scripts/ensure-pnpm.js",
    "lint": "eslint",
    "pretypecheck": "node scripts/ensure-pnpm.js",
    "typecheck": "tsc --noEmit",
    "pretest": "node scripts/ensure-pnpm.js",
    "test": "vitest run",
    "pretest:watch": "node scripts/ensure-pnpm.js",
    "test:watch": "vitest",
    "pree2e": "node scripts/ensure-pnpm.js",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
